{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/orchestrator.py": {
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/(.*)", 
      "dest": "api/orchestrator.py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}